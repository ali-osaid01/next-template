#!/bin/sh
# commit-msg: enforce Conventional Commits format
# https://www.conventionalcommits.org
#
# Valid types: feat, fix, chore, docs, style, refactor, perf, test, build, ci, revert
#
# Examples:
#   feat: add user authentication
#   fix(auth): correct token expiry logic
#   chore: update dependencies

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Allow merge commits and revert commits through unchanged
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert) "; then
  exit 0
fi

PATTERN="^(feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert)(\(.+\))?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌  Invalid commit message format."
  echo ""
  echo "    Expected: <type>(<scope>): <description>"
  echo "    Example:  feat(auth): add login page"
  echo ""
  echo "    Allowed types: feat fix chore docs style refactor perf test build ci revert"
  echo ""
  echo "    Your message: $COMMIT_MSG"
  echo ""
  exit 1
fi
